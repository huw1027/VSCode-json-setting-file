{
  // ============================================================
  // 编辑器核心体验
  // ============================================================
  "editor.fontSize": 15,
  "editor.fontFamily": "JetBrains Mono, 'Microsoft YaHei', Consolas, monospace",
  "editor.fontLigatures": true,
  "editor.lineHeight": 1.6,
  "editor.cursorBlinking": "phase",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.smoothScrolling": true,
  "editor.minimap.enabled": false,

  // 大文件处理
  "editor.largeFileOptimizations": true,

  // 预览行为
  "workbench.editor.enablePreview": false,

  // ============================================================
  // 主题
  // ============================================================
  "workbench.colorTheme": "GitHub Dark",

  // ============================================================
  // 文件关联（核心修复区）
  // ============================================================
  // 语言类型关联
  "files.associations": {
    "*.cla": "c",
    "*.cmd": "plaintext",
    "*.syscfg": "json"
  },

  // 编辑器类型关联（修复二进制检测问题）
  "workbench.editorAssociations": {
    "*.cla": "default"  // 强制文本编辑器
  },

  // 自动检测编码
  "files.autoGuessEncoding": true,

  // ============================================================
  // 代码导航与搜索
  // ============================================================
  "workbench.editor.revealIfOpen": true,

  // 代码折叠
  "editor.foldingStrategy": "indentation",
  "editor.showFoldingControls": "always",

  // 括号高亮
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": "active",

  // ============================================================
  // 滚动条
  // ============================================================
  "editor.scrollbar.horizontalScrollbarSize": 20,
  "editor.scrollbar.vertical": "visible",
  "workbench.colorCustomizations": {
    "scrollbarSlider.background": "#88888880",
    "scrollbarSlider.hoverBackground": "#aaaaaacc",
    "scrollbarSlider.activeBackground": "#ffffffcc",
    "editor.lineHighlightBackground": "#ffffff45",
    "editor.lineHighlightBorder": "#00000000",
    "list.inactiveSelectionBackground": "#264F78",
    "list.inactiveSelectionForeground": "#FFFFFF",
  },
  "editor.tokenColorCustomizations": {
    "comments": "#57ab5a"
  },

  // ============================================================
  // 安全
  // ============================================================
  "security.workspace.trust.untrustedFiles": "open",

  // ============================================================
  // AI 工具
  // ============================================================
  "github.copilot.nextEditSuggestions.enabled": true,
  "claudeCode.preferredLocation": "panel",

  // ============================================================
  // 终端
  // ============================================================
  "terminal.integrated.fontSize": 17,
  "terminal.integrated.fontFamily": "JetBrains Mono, 'Microsoft YaHei', Consolas, monospace",
  "terminal.integrated.initialHint": false,
  "terminal.integrated.gpuAcceleration": "off",
  "terminal.integrated.env.windows": {
    "HTTP_PROXY": "http://14a873aba4e22:47f1dc71ad@37.218.214.208:12323",
    "HTTPS_PROXY": "http://14a873aba4e22:47f1dc71ad@37.218.214.208:12323"
  },
  "terminal.integrated.profiles.windows": {
    "PowerShell": {
      "source": "PowerShell",
      "args": ["-ExecutionPolicy", "Bypass", "-NoExit", "-Command", "curl.exe -s --max-time 5 ifconfig.me"]
    }
  },
  "terminal.integrated.defaultProfile.windows": "PowerShell",

  // ============================================================
  // 代理
  // ============================================================
  "http.proxy": "http://14a873aba4e22:47f1dc71ad@37.218.214.208:12323",

  // ============================================================
  // 远程开发
  // ============================================================
  "remote.SSH.remotePlatform": {
    "connect.westc.gpuhub.com": "linux"
  },

  // ============================================================
  // Git
  // ============================================================
  "git.openRepositoryInParentFolders": "always",
  "git.enableSmartCommit": true,

  // ============================================================
  // clangd（保留你的路径）
  // ============================================================
  "clangd.path": "c:\\Users\\fengy\\AppData\\Roaming\\Cursor\\User\\globalStorage\\llvm-vs-code-extensions.vscode-clangd\\install\\21.1.8\\clangd_21.1.8\\bin\\clangd.exe",

  // ============================================================
  // 其他
  // ============================================================
  "chat.viewSessions.orientation": "stacked",

  // ============================================================
  // 性能优化
  // ============================================================
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/node_modules/**": true,
    "**/build/**": true,
    "**/Debug/**": true,
    "**/Release/**": true,
    "**/*.out": true,
    "**/*.map": true
  },

  "search.exclude": {
    "**/build": true,
    "**/Debug": true,
    "**/Release": true,
    "**/*.hex": true,
    "**/*.out": true,
    "**/*.obj": true
  },
  "editor.scrollbar.verticalScrollbarSize": 20,
  "workbench.iconTheme": "material-icon-theme",
  "json.schemas": [



  ],
  "launch": {
    "configurations": [],
    "compounds": []
  },
  "debug.console.fontFamily": "JetBrains Mono, 'JetBrains Mono', Consolas, monospace",
  "terminal.integrated.fontFamily": "JetBrains Mono, 'Noto Sans SC', Consolas, monospace",
  "notebook.markup.fontFamily": "JetBrains Mono, 'JetBrains Mono', Consolas, monospace",
  "notebook.output.fontFamily": "JetBrains Mono, 'JetBrains Mono', Consolas, monospace",
  "terminal.integrated.fontLigatures.fallbackLigatures": [
  "editor.scrollbar.verticalScrollbarSize": 20
    "<--",
